generator client {
  provider        = "prisma-client-js"
  output          = "../../prisma"
  previewFeatures = ["nativeDistinct", "relationJoins"]
  binaryTargets   = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
}

model BankSaving {
  id String @id @default(uuid()) @db.Uuid

  amount          Int
  durationDays    Int
  interestRateBps Int
  unlockAt        DateTime  @db.Timestamptz(3)
  claimedAt       DateTime? @db.Timestamptz(3)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([userId])
  @@index([userId, claimedAt])
  @@index([unlockAt])
  @@map("bank_saving")
}

model Dinoz {
  id                 Int         @id @default(autoincrement())
  name               String      @db.VarChar(32)
  canRename          Boolean     @default(false)
  raceId             Int
  display            String      @db.VarChar
  level              Int         @default(1)
  life               Int
  maxLife            Int
  experience         Int
  nbrUpFire          Int
  nbrUpWood          Int
  nbrUpWater         Int
  nbrUpLightning     Int
  nbrUpAir           Int
  nextUpElementId    Int
  nextUpAltElementId Int
  placeId            Int
  remaining          Int         @default(3)
  order              Int?
  createdDate        DateTime    @default(now()) @db.Timestamptz(3)
  updatedDate        DateTime    @updatedAt @db.Timestamptz(3)
  seed               String      @db.Uuid
  state              DinozState?
  stateTimer         DateTime?   @db.Timestamptz(3)

  catches          DinozCatch[]
  fight            Boolean                 @default(true)
  gather           Boolean                 @default(true)
  leaderId         Int?                    @map("following")
  leader           Dinoz?                  @relation("DinozFollowers", fields: [leaderId], references: [id])
  followers        Dinoz[]                 @relation("DinozFollowers")
  items            DinozItems[]
  skills           DinozSkills[]
  unlockableSkills DinozSkillsUnlockable[]
  status           DinozStatus[]
  missions         DinozMissions[]
  marketOffers     Offer[]                 @relation("OfferDinoz")
  FBTournamentStep Int                     @default(0)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  logs GameLog[] @relation("GameLogDinoz")

  @@index([userId])
  @@index([leaderId])
}

model DinozCatch {
  id        Int    @id @default(autoincrement())
  dinozId   Int
  hp        Int
  monsterId String
  dinoz     Dinoz  @relation(fields: [dinozId], references: [id], onDelete: Cascade)
}

model DinozItems {
  id      Int    @id() @default(autoincrement())
  itemId  Int
  dinozId Int?
  dinoz   Dinoz? @relation(fields: [dinozId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([dinozId])
  @@map("dinoz_item")
}

model DinozMissions {
  id          Int    @id @default(autoincrement())
  missionKey  String
  progression Int    @default(0)
  tracking    Int    @default(0)
  state       Json?

  isCompleted Boolean @default(false)

  startedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dinozId Int
  dinoz   Dinoz @relation(fields: [dinozId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([missionKey, dinozId])
  @@index([dinozId])
  @@index([missionKey])
  @@index([isCompleted])
  @@map("dinoz_mission")
}

model DinozSkills {
  id      Int     @id @default(autoincrement())
  skillId Int
  state   Boolean @default(true)
  dinozId Int?
  dinoz   Dinoz?  @relation(fields: [dinozId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([skillId, dinozId])
  @@index([dinozId])
  @@map("dinoz_skill")
}

model DinozSkillsUnlockable {
  id      Int    @id @default(autoincrement())
  skillId Int
  dinozId Int?
  dinoz   Dinoz? @relation(fields: [dinozId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("dinoz_skill_unlockable")
}

model DinozStatus {
  id       Int    @id @default(autoincrement())
  statusId Int
  dinozId  Int?
  dinoz    Dinoz? @relation(fields: [dinozId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([statusId, dinozId])
  @@index([dinozId])
  @@map("dinoz_status")
}

model ForcebrutTournamentOpponent {
  id Int @id @default(autoincrement())

  step Int @unique

  name    String @db.VarChar()
  raceId  Int
  display String @db.VarChar

  level   Int
  life    Int @default(100)
  maxLife Int @default(100)

  nbrUpFire      Int @default(0)
  nbrUpWood      Int @default(0)
  nbrUpWater     Int @default(0)
  nbrUpLightning Int @default(0)
  nbrUpAir       Int @default(0)

  skillIds Int[] @default([])

  enabled Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([enabled, step])
  @@map("forcebrut_tournament_opponent")
}

model GameLog {
  id        BigInt           @id @default(autoincrement())
  type      GameLogType
  retention GameLogRetention @default(TEMPORARY)

  values   String[] @default([])
  metadata Json?

  userId String? @db.Uuid
  user   User?   @relation("GameLogUser", fields: [userId], references: [id], onDelete: SetNull)

  dinozId Int?
  dinoz   Dinoz? @relation("GameLogDinoz", fields: [dinozId], references: [id], onDelete: SetNull)

  actorUserId String? @db.Uuid
  actorUser   User?   @relation("GameLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  userNameSnapshot  String?
  dinozNameSnapshot String?
  actorNameSnapshot String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([userId, dinozId, type])
  @@index([type, createdAt])
  @@index([retention, createdAt])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([dinozId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("game_log")
}

model GameLogHourly {
  id        BigInt      @id @default(autoincrement())
  type      GameLogType
  bucketAt  DateTime    @db.Timestamptz(3)
  total     Int         @default(0)
  createdAt DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt DateTime    @updatedAt @db.Timestamptz(3)

  @@unique([type, bucketAt])
  @@index([bucketAt])
  @@index([type, bucketAt])
  @@map("game_log_hourly")
}

model GameLogDaily {
  id        BigInt      @id @default(autoincrement())
  type      GameLogType
  day       DateTime    @db.Date
  total     Int         @default(0)
  createdAt DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt DateTime    @updatedAt @db.Timestamptz(3)

  @@unique([type, day])
  @@index([day])
  @@index([type, day])
  @@map("game_log_daily")
}

model JobDefinition {
  id      String  @id @default(cuid())
  key     String  @unique // ex: "reset-dinoz-shop"
  name    String
  type    JobType
  enabled Boolean @default(true)

  // Scheduling
  timezone    String @default("UTC")
  dailyHour   Int?
  dailyMinute Int?
  intervalMs  Int?

  // State
  status    JobStatus @default(IDLE)
  lastRunAt DateTime? @db.Timestamptz(3)
  nextRunAt DateTime? @db.Timestamptz(3)
  lastError String?

  // Locking (multi-instance safe)
  lockedAt     DateTime? @db.Timestamptz(3)
  lockedBy     String?
  lockTimeoutS Int       @default(300)

  runs JobRun[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([enabled, nextRunAt])
  @@map("job_definition")
}

model JobRun {
  id    String        @id @default(cuid())
  jobId String
  job   JobDefinition @relation(fields: [jobId], references: [id], onDelete: Cascade)

  startedAt   DateTime  @default(now()) @db.Timestamptz(3)
  endedAt     DateTime? @db.Timestamptz(3)
  success     Boolean?
  error       String?
  triggeredBy String?

  @@index([jobId, startedAt])
  @@map("job_run")
}

model News {
  id   Int      @id @default(autoincrement())
  slug String   @unique @db.VarChar
  type NewsType @default(update)

  image         Bytes?
  imageMimeType String? @db.VarChar

  isPublished Boolean   @default(false)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations NewsTranslation[]
  poll         Poll?
  likedBy      NewsLike[]

  @@index([type])
  @@index([isPublished, publishedAt])
  @@index([createdAt])
  @@map("news")
}

model NewsTranslation {
  id      Int      @id @default(autoincrement())
  newsId  Int
  lang    Language
  title   String   @db.VarChar
  excerpt String?  @db.VarChar
  content String   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@unique([newsId, lang])
  @@index([lang])
  @@map("news_translations")
}

model Offer {
  id           Int         @id @default(autoincrement())
  sellerId     String?     @db.Uuid
  sellerName   String
  endDate      DateTime    @db.Timestamptz(3)
  dinozId      Int?
  dinozDetails String?
  total        Int
  status       OfferStatus @default(ONGOING)

  seller User?  @relation("OfferSeller", fields: [sellerId], references: [id], onDelete: SetNull)
  dinoz  Dinoz? @relation("OfferDinoz", fields: [dinozId], references: [id], onDelete: SetNull)

  items OfferItem[]
  bids  OfferBid[]

  @@index([status, endDate])
  @@index([sellerId])
  @@index([dinozId])
}

model OfferItem {
  id           Int     @id @default(autoincrement())
  offerId      Int
  itemId       Int
  quantity     Int
  isIngredient Boolean

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
}

model OfferBid {
  id       Int     @id @default(autoincrement())
  offerId  Int
  userId   String? @db.Uuid
  userName String
  value    Int

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([offerId])
  @@index([userId])
}

model Poll {
  id       Int      @id @default(autoincrement())
  newsId   Int      @unique
  isActive Boolean  @default(true)
  endAt    DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  news    News         @relation(fields: [newsId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]

  @@index([isActive, endAt])
  @@map("polls")
}

model PollOption {
  id        Int @id @default(autoincrement())
  pollId    Int
  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  poll         Poll                    @relation(fields: [pollId], references: [id], onDelete: Cascade)
  translations PollOptionTranslation[]
  votes        PollVote[]

  @@unique([pollId, sortOrder])
  @@index([pollId])
  @@map("poll_options")
}

model PollOptionTranslation {
  id           Int      @id @default(autoincrement())
  pollOptionId Int
  lang         Language
  label        String   @db.VarChar

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pollOption PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)

  @@unique([pollOptionId, lang])
  @@index([lang])
  @@map("poll_option_translations")
}

model PollVote {
  id           Int      @id @default(autoincrement())
  pollId       Int
  pollOptionId Int
  userId       String   @db.Uuid
  votedAt      DateTime @default(now())

  poll       Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollOption PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId], name: "unique_user_vote_per_poll")
  @@index([pollId])
  @@index([pollOptionId])
  @@index([userId])
  @@map("poll_votes")
}

model NewsLike {
  newsId    Int
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([newsId, userId])
  @@index([userId])
  @@map("news_likes")
}

model Ranking {
  id         Int @id @default(autoincrement())
  dinozCount Int @default(0)
  points     Int @default(0)
  average    Int @default(0)
  completion Int @default(0)
  dojo       Int @default(0)

  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Secret {
  key   String @id @db.VarChar
  value String @db.VarChar

  @@map("secret")
}

model SignupDeviceMonthCounter {
  id          Int      @id @default(autoincrement())
  monthKey    String
  deviceToken String
  count       Int      @default(0)
  expiresAt   DateTime @db.Timestamptz(3)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  @@unique([monthKey, deviceToken])
  @@index([monthKey])
  @@index([expiresAt])
}

model SignupIpMonthCounter {
  id        Int      @id @default(autoincrement())
  monthKey  String
  ipToken   String
  count     Int      @default(0)
  expiresAt DateTime @db.Timestamptz(3)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@unique([monthKey, ipToken])
  @@index([monthKey])
  @@index([expiresAt])
}

model User {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  password    String
  role        Role      @default(PLAYER)
  createdDate DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime? @updatedAt @db.Timestamptz(3)
  lastLogin   DateTime  @default(now()) @db.Timestamptz(3)

  clanId          Int?
  clan            Clan?            @relation(fields: [clanId], references: [id], onDelete: SetNull)
  leaderOf        Clan?            @relation("leader")
  ClanHistory     ClanHistory[]
  ClanJoinRequest ClanJoinRequest? @relation("clanRequest")
  ClanMember      ClanMember?
  ClanMessage     ClanMessage[]

  gathers       UserGather[]
  ingredients   UserIngredients[]
  items         UserItems[]
  profile       UserProfile?
  ranking       Ranking?
  rewards       UserRewards[]
  scenarios     UserScenario[]
  statsTracking UserTracking[]
  wallets       UserWallet[]

  marketOffers Offer[]    @relation("OfferSeller")
  marketBids   OfferBid[]

  dinoz     Dinoz[]
  dinozShop UserDinozShop[]

  leader      Boolean @default(false)
  engineer    Boolean @default(false)
  cooker      Boolean @default(false)
  shopKeeper  Boolean @default(false)
  merchant    Boolean @default(false)
  priest      Boolean @default(false)
  teacher     Boolean @default(false)
  matelasseur Boolean @default(false)
  messie      Boolean @default(false)

  newsLikes NewsLike[]
  pollVotes PollVote[]

  createdConversations Conversation[] @relation("CreatedConversations")
  conversationLinks    Participant[]
  sentMessages         Message[]

  logs      GameLog[] @relation("GameLogUser")
  actedLogs GameLog[] @relation("GameLogActor")

  discoveredSkills Int[] @default([])

  bankSavings BankSaving[]
}

model UserDinozShop {
  id      Int     @id @default(autoincrement())
  raceId  Int
  display String  @db.VarChar
  userId  String? @db.Uuid
  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("user_dinoz_shop")
}

model UserGather {
  id     Int     @id @default(autoincrement())
  place  Int
  type   Int
  grid   Int[]
  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@map("user_gather")
}

model UserIngredients {
  id           Int    @default(autoincrement())
  ingredientId Int
  quantity     Int
  userId       String @db.Uuid
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([ingredientId, userId])
  @@index([userId])
  @@map("user_ingredients")
}

model UserItems {
  id       Int    @default(autoincrement())
  itemId   Int
  quantity Int
  userId   String @db.Uuid
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([itemId, userId])
  @@index([userId])
  @@map("user_items")
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  avatar      Bytes?
  avatarType  String?
  language    Language? @default(FR)
  gender      Gender?
  age         Int?
  description String?
  customText  String?
}

model UserRewards {
  id       Int     @id @default(autoincrement())
  rewardId Int
  userId   String? @db.Uuid
  user     User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rewardId, userId])
  @@index([userId])
}

model UserScenario {
  id Int @id @default(autoincrement())

  scenarioKey String
  progression Int    @default(0)
  tracking    Int    @default(0)
  state       Json?

  startedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([scenarioKey, userId])
  @@index([userId])
  @@index([scenarioKey])
  @@map("user_scenario")
}

model UserTracking {
  id       Int    @id @default(autoincrement())
  stat     String
  quantity Int    @default(0)
  userId   String @db.Uuid
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([stat, userId])
  @@index([userId])
  @@index([stat])
  @@map("statsTracking")
}

model UserWallet {
  id     String    @id @default(uuid()) @db.Uuid
  type   MoneyType
  amount Int       @default(0)
  userId String    @db.Uuid
  user   User      @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

enum ConversationType {
  DIRECT
  GROUP
  SYSTEM
}

model Conversation {
  id              String           @id @default(uuid()) @db.Uuid
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  type            ConversationType @default(DIRECT)
  title           String?
  createdById     String?          @db.Uuid
  pinnedMessageId Int?             @unique

  createdBy     User?         @relation("CreatedConversations", fields: [createdById], references: [id], onDelete: SetNull)
  pinnedMessage Message?      @relation("PinnedMessage", fields: [pinnedMessageId], references: [id], onDelete: SetNull)
  participants  Participant[]
  messages      Message[]

  @@index([createdAt])
  @@index([updatedAt])
  @@map("conversation")
}

model Participant {
  id               Int       @id @default(autoincrement())
  conversationId   String    @db.Uuid
  userId           String?   @db.Uuid
  joinedAt         DateTime  @default(now())
  leftAt           DateTime?
  userNameSnapshot String
  lastReadAt       DateTime?
  isArchived       Boolean   @default(false)
  isMuted          Boolean   @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@map("conversation_participant")
}

model Message {
  id                 Int       @id @default(autoincrement())
  conversationId     String    @db.Uuid
  senderId           String?   @db.Uuid
  content            String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  senderNameSnapshot String

  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?         @relation(fields: [senderId], references: [id], onDelete: SetNull)
  pinnedIn     Conversation? @relation("PinnedMessage")

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("message")
}

model Clan {
  id            Int               @id @default(autoincrement())
  name          String            @unique
  treasureValue Int               @default(0)
  creationDate  DateTime          @default(now()) @db.Timestamp(6)
  banner        Bytes?
  leaderId      String            @unique @db.Uuid
  langs         Language[]
  leader        User              @relation("leader", fields: [leaderId], references: [id])
  history       ClanHistory[]
  joinRequests  ClanJoinRequest[]
  members       ClanMember[]      @relation("member")
  pages         ClanPage[]
  ingredients   ClanIngredient[]
  discussion    ClanMessage[]
  users         User[]
}

model ClanJoinRequest {
  id     Int      @id @default(autoincrement())
  clanId Int
  date   DateTime @default(now()) @db.Timestamp(6)
  userId String   @unique @db.Uuid
  clan   Clan     @relation(fields: [clanId], references: [id])
  user   User     @relation("clanRequest", fields: [userId], references: [id], onDelete: Cascade)
}

model ClanIngredient {
  id           Int  @id @default(autoincrement())
  ingredientId Int
  quantity     Int
  clanId       Int
  clan         Clan @relation(fields: [clanId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([ingredientId, clanId])
  @@map("clan_ingredient")
}

model ClanMessage {
  id         Int      @id @default(autoincrement())
  clanId     Int
  date       DateTime @default(now()) @db.Timestamp(6)
  content    String
  authorId   String?  @db.Uuid
  authorName String
  author     User?    @relation(fields: [authorId], references: [id])
  clan       Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([id, clanId])
  @@index([clanId])
  @@map("clan_messages")
}

model ClanHistory {
  id            Int      @id @default(autoincrement())
  clanId        Int
  date          DateTime @default(now()) @db.Timestamp(6)
  type          String   @default("CLAN_CREATED")
  authorId      String?  @db.Uuid
  authorMessage String
  author        User?    @relation(fields: [authorId], references: [id])
  clan          Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ClanMember {
  id       Int      @id @default(autoincrement())
  clanId   Int
  dateJoin DateTime @default(now()) @db.Timestamp(6)
  nickname String?
  rights   String[] @default([])
  donation Int      @default(0)
  userId   String   @unique @db.Uuid
  clan     Clan     @relation("member", fields: [clanId], references: [id])
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clanId])
}

model ClanPage {
  id      Int     @id @default(autoincrement())
  home    Boolean
  public  Boolean
  name    String
  content String  @default("")
  clanId  Int
