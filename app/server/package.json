		"@fastify/swagger": "^9.7.0",
		"@fastify/swagger-ui": "^5.2.6",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"bcrypt": "^6.0.0",
		"discord.js": "^14.26.4",
